                        Visibility="Collapsed"
                        Panel.ZIndex="100"
                        SizeChanged="CommandsPanel_SizeChanged">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="CommandsPanelTransform" X="0"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Background="{DynamicResource Surface}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Commands"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"
                                       Margin="14,10"/>
                            <Button Grid.Column="1" Content="✕"
                                    Click="BtnCloseCommands_Click"
                                    Style="{StaticResource GhostButton}"
                                    Padding="10,4" Margin="6"
                                    ToolTip="Close (Esc)"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" Margin="20,16,20,16"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel MaxWidth="640" HorizontalAlignment="Left">

                                <TextBlock Text="Team chat commands"
                                           FontWeight="Bold" FontSize="18"
                                           Foreground="{DynamicResource TextPrimary}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Foreground="{DynamicResource TextSubtle}"
                                           FontSize="12" Margin="0,0,0,16"
                                           TextWrapping="Wrap"
                                           Text="Anyone in your team can type these in the in-game team chat. The app reacts when it sees them."/>

                                <Border Background="{DynamicResource Surface}" Padding="14" CornerRadius="6"
                                        Margin="0,0,0,8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock FontFamily="Consolas, Courier New" FontSize="14"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontWeight="SemiBold" Text="!leader"/>
                                        <TextBlock Foreground="{DynamicResource TextSubtle}" FontSize="12"
                                                   Margin="0,4,0,4" TextWrapping="Wrap"
                                                   Text="Auto-promote the sender to team leader. Anyone on your team can type this in team chat to grab the leader role without you having to do it manually."/>
                                        <TextBlock Foreground="#7BA8E8" FontFamily="Consolas, Courier New" FontSize="11"
                                                   Text="[Auto-Promote] Moe (76561198030515046) requested promotion."/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Foreground="{DynamicResource TextSubtle}" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,12,0,0"
                                           Text="More commands can be added here as the app grows."/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!--
                    Slide-in player report overlay: covers all 3 rows of the right column.
                    ZIndex 100 puts the Report's header (and its ✕ button) above the
                    TrackerPanel (Z=50), so when both are open the Report is the visible
                    modal and clicking ✕ closes the Report — leaving the Tracker open
                    behind it.
                -->
                <Border x:Name="ReportPanel" Grid.RowSpan="3"
                        Background="{DynamicResource AppBg}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed"
                        Panel.ZIndex="100"
                        SizeChanged="ReportPanel_SizeChanged">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="ReportPanelTransform" X="0"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Background="{DynamicResource Surface}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtReportTitle" Grid.Column="0"
                                       Text="Player Activity Report"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"
                                       Margin="14,10"/>
                            <Button Grid.Column="1" Content="✕"
                                    Click="BtnCloseReport_Click"
                                    Style="{StaticResource GhostButton}"
                                    Padding="10,4" Margin="6"
                                    ToolTip="Close report (Esc)"/>
                        </Grid>
                        <wv2:WebView2 x:Name="ReportWebView" Grid.Row="1"/>
                    </Grid>
                </Border>

                <!--
                    Slide-in Tracker overlay: same scaffold as ReportPanel/CommandsPanel.
                    Covers all 3 rows of the right column. The actual Tracker UI is reparented
                    in/out of TrackerHostInPanel by Views/MainWindow/Tracker/MainWindow.Tracker.Panel.cs.
                -->
                <Border x:Name="TrackerPanel" Grid.RowSpan="3"
                        Background="{DynamicResource AppBg}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed"
                        Panel.ZIndex="50">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="TrackerPanelTransform" X="0"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Background="{DynamicResource Surface}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Tracker"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"
                                       Margin="14,10"/>
                            <Button Grid.Column="1" Content="✕"
                                    Click="BtnCloseTrackerPanel_Click"
                                    Style="{StaticResource GhostButton}"
                                    Padding="10,4" Margin="6"
                                    ToolTip="Close tracker (Esc)"/>
                        </Grid>
                        <ContentControl x:Name="TrackerHostInPanel" Grid.Row="1"
                                        Margin="14,8,14,14"/>
                    </Grid>
                </Border>

                <!--
                    Slide-in patch-notes overlay. Same scaffold as ReportPanel /
                    TrackerPanel. Body content lives in views:PatchNotesView so
                    edits to version history only touch one file.
                -->
                <Border x:Name="PatchNotesPanel" Grid.RowSpan="3"
                        Background="{DynamicResource AppBg}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed"
                        Panel.ZIndex="100">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="PatchNotesPanelTransform" X="0"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Background="{DynamicResource Surface}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Patch Notes &amp; Version History"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"
                                       Margin="14,10"/>
                            <Button Grid.Column="1" Content="✕"
                                    Click="BtnClosePatchNotesPanel_Click"
                                    Style="{StaticResource GhostButton}"
                                    Padding="10,4" Margin="6"
                                    ToolTip="Close (Esc)"/>
                        </Grid>
                        <!--
                            MaxHeight is hard-bound to the right-column's ActualHeight,
                            so the ScrollViewer always has a finite viewport regardless
                            of how the inner Grid.Row="*" cell sizes during the first
                            measure pass. Without this, the scroll didn't kick in until
                            something else (like connecting to a server) forced a fresh
                            layout pass on the right column.
                        -->
                        <ScrollViewer x:Name="PatchNotesScroll"
                                      Grid.Row="1" Margin="14,8,14,14"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="{Binding ActualHeight, ElementName=RightColumnBorder}">
                            <views:PatchNotesView/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        <!--
            Busy overlay: shown while a long-running action (update check,
            installer download, etc.) is in flight. Single instance — there
            were two stacked Grids using the old teal palette before; the
            zinc-900 card here matches the rest of the shadcn modals.
        -->
        <Grid Background="#80000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
              IsHitTestVisible="True"
              Panel.ZIndex="9999">
            <Border Background="#18181B"
                    BorderBrush="#27272A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    Width="320"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding BusyText}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FAFAFA"
                               TextAlignment="Center"
                               Margin="0,0,0,12"/>
                    <ProgressBar IsIndeterminate="True"
                                 Height="4"
                                 Background="#27272A"
                                 BorderThickness="0"
                                 Foreground="#FAFAFA"/>
                </StackPanel>
            </Border>
        </Grid>


    </Grid>
</Window>
    
