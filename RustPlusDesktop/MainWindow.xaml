                    </Border>

                    <!--
                        Toolbox mirrors EventDockHost's styling (background / border /
                        radius / padding) so the right edge reads as two sibling panels
                        with matching chrome. Translate-Y is bound to the host Border's
                        ActualHeight (not the inner StackPanel) so a 6 px gap sits
                        between them regardless of how many event icons are docked.
                    -->
                    <Border x:Name="OverlayToolbox"
        Background="#CC1E1E1E"
        BorderBrush="#27272A"
        BorderThickness="1"
        CornerRadius="8"
        Padding="6"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Margin="15,21,15,0"
        Visibility="Collapsed"
        Panel.ZIndex="9000">
                        <!--
                            MaxHeight = WebViewHost.ActualHeight - EventDockHost.ActualHeight
                            - 60 px (top margin + dock margin + bottom inset). Combined with
                            the inner Viewbox (StretchDirection=DownOnly) this lets the toolbox
                            shrink when the right-column shortens, but keep its natural size
                            on a tall window.
                        -->
                        <Border.MaxHeight>
                            <MultiBinding Converter="{StaticResource AvailableHeight}" ConverterParameter="60">
                                <Binding Path="ActualHeight" ElementName="WebViewHost"/>
                                <Binding Path="ActualHeight" ElementName="EventDockHost"/>
                            </MultiBinding>
                        </Border.MaxHeight>
                        <Border.RenderTransform>
                            <TranslateTransform Y="{Binding ActualHeight, ElementName=EventDockHost}"/>
                        </Border.RenderTransform>
                        <!--
                            Tool buttons render at 38×38 by default, but the whole stack
                            is wrapped in a Viewbox with StretchDirection="DownOnly" so
                            on a tall window we keep the natural size, while on a short
                            window the toolbox scales down to fit the space left by
                            EventDockHost. Click activates the tool AND opens its
                            settings popup (size / colour / icon picker) — moved off
                            right-click so the menu is discoverable.
                        -->
                        <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                        <StackPanel>
                            <StackPanel.Resources>
                                <Style TargetType="Button" x:Key="OverlayToolboxButton">
                                    <Setter Property="Width" Value="38"/>
                                    <Setter Property="Height" Value="38"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="Padding" Value="6"/>
                                </Style>
                            </StackPanel.Resources>

                            <!-- Zeichnen -->
                            <Button x:Name="ToolDrawButton"
                                    Style="{StaticResource OverlayToolboxButton}"
                                    ToolTip="Draw — click to activate &amp; pick size / colour"
                                    Click="ToolDrawButton_Click">
                                <Image Source="pack://application:,,,/icons/pen.png"/>
                            </Button>

                            <!-- Text -->
                            <Button x:Name="ToolTextButton"
                                    Style="{StaticResource OverlayToolboxButton}"
                                    ToolTip="Place text — click to activate &amp; pick colour / size"
                                    Click="ToolTextButton_Click">
                                <Image Source="pack://application:,,,/icons/text.png"/>
                            </Button>

                            <!-- Icons -->
                            <Button x:Name="ToolIconButton"
                                    Style="{StaticResource OverlayToolboxButton}"
                                    ToolTip="Place icon — click to pick which icon to drop"
                                    Click="ToolIconButton_Click">
                                <Image Source="pack://application:,,,/icons/pin.png"/>
                            </Button>

                            <!-- Radierer -->
                            <Button x:Name="ToolEraseButton"
                                    Style="{StaticResource OverlayToolboxButton}"
                                    ToolTip="Eraser — click to activate &amp; pick size"
                                    Click="ToolEraseButton_Click">
                                <Image Source="pack://application:,,,/icons/eraser.png"/>
                            </Button>

                            <Separator Margin="4,4"/>

                            <!-- Löschen  -->
                            <Button x:Name="ToolTrashButton"
                                    Style="{StaticResource OverlayToolboxButton}"
                                    ToolTip="Delete own overlay"
                                    Click="ToolTrashButton_Click">
                                <Image Source="pack://application:,,,/icons/trash.png"/>
                            </Button>

                            <!-- Upload / Teilen -->
                            <Button x:Name="ToolUploadButton"
                                    Style="{StaticResource OverlayToolboxButton}"
                                    ToolTip="Upload own Overlay / share"
                                    Click="ToolUploadButton_Click">
                                <Image Source="pack://application:,,,/icons/upload.png"/>
                            </Button>
                        </StackPanel>
                        </Viewbox>
                    </Border>

